meta {
  name: List Areas
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/core/areas
  body: none
  auth: bearer
}

headers {
  X-Tenant-ID: {{tenantId}}
  X-Tenant-Slug: {{tenantSlug}}
}

assert {
  res.status: eq 200
}

docs {
