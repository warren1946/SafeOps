meta {
  name: List Sites
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/core/sites
  body: none
  auth: bearer
}

headers {
  X-Tenant-ID: {{tenantId}}
  X-Tenant-Slug: {{tenantSlug}}
}

assert {
  res.status: eq 200
}

docs {
