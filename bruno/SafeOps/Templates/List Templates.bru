meta {
  name: List Templates
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/templates
  body: none
  auth: bearer
}

headers {
  X-Tenant-ID: {{tenantId}}
  X-Tenant-Slug: {{tenantSlug}}
}

assert {
  res.status: eq 200
}

docs {
  # List Templates (v1 path)
  
  ## Expected Response
  - Status: 200 OK
  - Returns list of inspection templates
}
