  X-Tenant-Slug: {{tenantSlug}}
}

assert {
  res.status: eq 401
}

docs {
  # Access Protected Endpoint Without Token
  
  ## Expected Response
  - Status: 401 Unauthorized
  - Request should be rejected
}
