meta {
  name: Refresh Token Invalid
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/api/v1/auth/refresh
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "refreshToken": "invalid_refresh_token"
  }
}

assert {
  res.status: eq 401
}

docs {
  # Refresh Token - Invalid
  
  ## Expected Response
  - Status: 401 Unauthorized
}
