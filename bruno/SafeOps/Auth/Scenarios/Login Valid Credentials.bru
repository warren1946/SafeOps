meta {
  name: Login Valid Credentials
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{validEmail}}",
    "password": "{{validPassword}}"
  }
}

script:post-response {
  // Save tokens for subsequent requests
  const json = res.getBody();
  if (json.data && json.data.accessToken) {
    bru.setVar('accessToken', json.data.accessToken);
    bru.setVar('refreshToken', json.data.refreshToken);
    bru.setVar('userId', json.data.id);
    bru.setVar('userEmail', json.data.email);
    bru.setVar('userRoles', JSON.stringify(json.data.roles));
  }
}

docs {
  # Login with Valid Credentials
  
  ## Expected Response
  - Status: 200 OK
  - Body contains: accessToken, refreshToken, user data
  - Role should match expected role
}
