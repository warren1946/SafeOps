# SafeOps Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!
#
# Usage:
#   1. Copy this file: cp .env.example .env
#   2. Generate secrets: ./scripts/generate-secrets.sh (if available)
#   3. Fill in all REQUIRED variables
#   4. Source the file: source .env (Linux/Mac) or use appropriate method for Windows

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Frontend API Configuration
SAFEOPS_API_URL=http://localhost:8080

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/safeops
SPRING_DATASOURCE_USERNAME=safeops
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# PostgreSQL Database (for Docker Compose)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT Secrets - Generate strong secrets for production!
# Use: openssl rand -base64 64
APP_JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS_LONG
APP_JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS_LONG

# Optional: API Server URL for Swagger/OpenAPI documentation
# APP_API_SERVER_URL=https://api.yourdomain.com

# Monitoring Tools (Docker Compose)
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# =============================================================================
# OPTIONAL VARIABLES (with defaults)
# =============================================================================

# PgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@safeops.com

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin

# =============================================================================
# EXTERNAL SERVICES (Uncomment and configure as needed)
# =============================================================================

# AWS S3 for file storage
# AWS_S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

# Email Services
# SENDGRID_API_KEY=your-key
# TWILIO_ACCOUNT_SID=your-sid
# TWILIO_AUTH_TOKEN=your-token

# AI Providers
# OPENAI_API_KEY=your-key
# AWS_REKOGNITION_ACCESS_KEY=your-key
# AWS_REKOGNITION_SECRET_KEY=your-secret

# Redis (for distributed caching)
# SPRING_REDIS_HOST=localhost
# SPRING_REDIS_PORT=6379
# SPRING_REDIS_PASSWORD=
